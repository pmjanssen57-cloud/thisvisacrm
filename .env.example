# Temporary fallback during the Netlify Identity transition.
# Set this in Netlify Site configuration, not in the source code repository.
CRM_ACCESS_TOKEN=replace-with-a-long-random-internal-access-code

# Netlify Database is normally injected by Netlify.
# If needed, the app also supports NETLIFY_DB_URL, NETLIFY_DATABASE_URL or DATABASE_URL.

# Netlify Identity is enabled in the Netlify UI, not through an environment variable.
# Set Identity registration to invite-only before inviting advisers.

# Microsoft Graph email sending. Add real values in Netlify environment variables only.
MICROSOFT_TENANT_ID=replace-with-tenant-id
MICROSOFT_CLIENT_ID=replace-with-client-id
MICROSOFT_CLIENT_SECRET=replace-with-client-secret
MICROSOFT_NOTIFICATION_FROM_EMAIL=THiS@turnerhopkins.co.nz
MICROSOFT_NOTIFICATION_FROM_NAME=Turner Hopkins Immigration Specialists
