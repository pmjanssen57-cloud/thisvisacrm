# Optional emergency fallback during the Netlify Identity transition.
# Leave unset once invited-user Identity login is working.
# The CRM no longer enters open prototype mode when this is missing.
CRM_ACCESS_TOKEN=replace-with-a-long-random-internal-access-code

# Netlify Database is normally injected by Netlify.
# If needed, the app also supports NETLIFY_DB_URL, NETLIFY_DATABASE_URL or DATABASE_URL.

# Netlify Identity is enabled in the Netlify UI, not through an environment variable.
# Set Identity registration to invite-only before inviting advisers.

# Microsoft Graph email sending. Add real values in Netlify environment variables only.
MICROSOFT_TENANT_ID=replace-with-tenant-id
MICROSOFT_CLIENT_ID=replace-with-client-id
MICROSOFT_CLIENT_SECRET=replace-with-client-secret
MICROSOFT_NOTIFICATION_FROM_EMAIL=THiS@turnerhopkins.co.nz
MICROSOFT_NOTIFICATION_FROM_NAME=Turner Hopkins Immigration Specialists

# Optional: override the public assessment form link used in contact follow-up emails.
# If omitted, the CRM will use the Turner Hopkins public assessment page below.
PUBLIC_INTAKE_FORM_URL=https://www.turnerhopkinsimmigration.co.nz/assessment

# Optional: override the public CRM base URL used in generated booking links.
THIS_CRM_BASE_URL=https://thisvisacrm.netlify.app

# Optional: recipients for new seminar registration notifications.
# If omitted, the CRM falls back to INTAKE_NOTIFICATION_RECIPIENTS or the Turner Hopkins default recipients.
SEMINAR_NOTIFICATION_RECIPIENTS=paul.janssen@turnerhopkins.co.nz,sejoo.han@turnerhopkins.co.nz


# Optional comma-separated browser origins allowed for cross-origin API calls.
# Same-origin CRM requests do not need this. The defaults cover the production Netlify app and Turner Hopkins website.
CORS_ALLOWED_ORIGINS=https://thisvisacrm.netlify.app,https://www.turnerhopkinsimmigration.co.nz,https://turnerhopkinsimmigration.co.nz


# Optional: override SMC calculator notification recipients if no active adviser emails are available.
# Comma-separated list. Active adviser emails in CRM are used first.
SMC_CALCULATOR_NOTIFICATION_EMAILS=

# Optional: override the consultation link included in SMC calculator result emails.
SMC_CALCULATOR_CONSULTATION_URL=https://www.turnerhopkinsimmigration.co.nz/visa-consultation

# Optional: public calculator URL used in internal notification emails.
SMC_CALCULATOR_URL=https://thisvisacrm.netlify.app/smc-work-experience-calculator.html


# Secure CRM Backup Centre.
# Identity users with the Admin or Manager role can create and download backups.
# Temporary encrypted archives are deleted by the hourly cleanup function after this many hours.
# Supported range: 1 to 168 hours. Default: 24.
CRM_BACKUP_RETENTION_HOURS=24

